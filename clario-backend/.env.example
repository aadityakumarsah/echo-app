# ===== REQUIRED =====
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use the service_role secret (not anon) so the backend can call PostgREST without RLS blocking inserts.
SUPABASE_SECRET_KEY=your-service-role-secret-key-here

GEMINI_API_KEY=your-gemini-api-key-here

# ===== STRIPE (REQUIRED FOR PAYMENTS) =====
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe dashboard (Products → Prices)
STRIPE_PRICE_WEEKLY=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# ===== OPTIONAL =====
# Environment: 'development' or 'production' (default: development)
# Set to 'production' to disable auto-reload and hot module reloading
ENV=development

# Server configuration
HOST=0.0.0.0
PORT=8000

# CORS: Comma-separated list of allowed origins
# Default: http://localhost:3000,http://localhost:5173,http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Optional: model for POST /sessions/{id}/report (default gemini-2.0-flash)
# GEMINI_REPORT_MODEL=gemini-2.0-flash
